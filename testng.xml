<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">

<!--
    testng.xml — Master Test Suite File
    Location  : selenium-demo/testng.xml   (project ROOT, same level as pom.xml)

    This file tells TestNG:
      - What the suite is called       (shown in the HTML report title)
      - Which test groups exist        (each <test> block = one group in the report)
      - Which classes belong to each   (each <class> = one test file)

    To RUN:
      Eclipse  → Right-click testng.xml → Run As → TestNG Suite
      Maven    → Right-click project    → Run As → Maven test

    REPORT is generated at:
      target/surefire-reports/index.html   ← open this in Chrome after the run
-->

<suite name="AI Resume Builder - Automation Suite" verbose="1">

    <!-- ── Group 1: Create Resume ──────────────────────────────────────────── -->
    <test name="Create Resume Test">
        <classes>
            <class name="tests.CreateResumeTest"/>
        </classes>
    </test>

    <!-- ── Group 2: Login and Create ───────────────────────────────────────── -->
    <test name="Login And Create Test">
        <classes>
            <class name="tests.LoginAndCreateTest"/>
        </classes>
    </test>

    <!-- ── Group 3: AI Resume Builder ──────────────────────────────────────── -->
    <test name="AI Resume Builder Test">
        <classes>
            <class name="tests.AIResumeBuilderTest"/>
        </classes>
    </test>

    <!-- ── Group 4: Upload Resume ───────────────────────────────────────────── -->
    <test name="Upload Resume Test">
        <classes>
            <class name="tests.UploadResumeTest"/>
        </classes>
    </test>

</suite>