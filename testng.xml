<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">

<suite name="AI Resume Builder - Automation Suite" 
       verbose="1"
       parallel="tests"
       thread-count="4">

    <!-- ── Group 1: Create Resume ──────────────────────────────────────────── -->
    <test name="Create Resume Test">
        <classes>
            <class name="tests.CreateResumeTest"/>
        </classes>
    </test>


    <!-- ── Group 2: Login and Create ───────────────────────────────────────── -->
    <test name="Login And Create Test">
        <classes>
            <class name="tests.LoginAndCreateTest"/>
        </classes>
    </test>

    <!-- ── Group 3: AI Resume Builder ──────────────────────────────────────── -->
    <test name="AI Resume Builder Test">
        <classes>
            <class name="tests.AIResumeBuilderTest"/>
        </classes>
    </test>

    <!-- ── Group 4: Upload Resume ───────────────────────────────────────────── -->
    <test name="Upload Resume Test">
        <classes>
            <class name="tests.UploadResumeTest"/>
        </classes>
    </test>

</suite>